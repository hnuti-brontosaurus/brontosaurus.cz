{
	"name": "hnuti-brontosaurus/wp-theme",
	"description": "WP theme for Hnutí Brontosaurus",
	"require": {
		"grifart/geocoding-client": "^0.2.0",
		"hnuti-brontosaurus/php-bis-api-client": "^5.0.0",
		"nette/neon": "^3.2",
		"nette/utils": "^4.0",
		"tracy/tracy": "^2.8"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.0",
		"szepeviktor/phpstan-wordpress": "^2.0"
	},
	"scripts": {
		"phpstan": "phpstan analyze --no-progress --no-interaction -c phpstan.neon"
	},
	"autoload": {
		"psr-4": {
			"HnutiBrontosaurus\\Theme\\": ".",
			"HnutiBrontosaurus\\Theme\\Events\\": "hb-events"
		},
		"classmap": [
			"exceptions.php"
		]
	},
	"config": {
		"platform": {
			"php": "8.2.0"
		},
		"sort-packages": true,
		"allow-plugins": {
			"php-http/discovery": false
		}
	},
	"repositories": [
		{
			"url": "https://github.com/grifart/geocoding-client.git",
			"type": "vcs"
		},
		{
			"url": "https://github.com/hnuti-brontosaurus/php-bis-api-client.git",
			"type": "vcs"
		}
	]
}
